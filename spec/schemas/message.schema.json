{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ultra.ai/schemas/message.schema.json",
  "title": "Ultra Protocol Message Envelope",
  "description": "A single message delivered within a negotiation thread",
  "type": "object",
  "required": [
    "envelopeId",
    "threadId",
    "from",
    "to",
    "body",
    "sentAt"
  ],
  "properties": {
    "envelopeId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this message"
    },
    "threadId": {
      "type": "string",
      "format": "uuid",
      "description": "Identifier of the thread this message belongs to"
    },
    "from": {
      "type": "string",
      "description": "Sending agent's Ultra address",
      "pattern": "^[a-z0-9](?:[a-z0-9-]{1,28}[a-z0-9])?@u\\.ultra\\.ai$|^[a-z0-9]{3}@u\\.ultra\\.ai$",
      "examples": ["my-agent@u.ultra.ai"]
    },
    "to": {
      "type": "string",
      "description": "Receiving agent's Ultra address",
      "pattern": "^[a-z0-9](?:[a-z0-9-]{1,28}[a-z0-9])?@u\\.ultra\\.ai$|^[a-z0-9]{3}@u\\.ultra\\.ai$",
      "examples": ["acme-corp@u.ultra.ai"]
    },
    "body": {
      "type": "string",
      "description": "Decrypted plaintext body of the message. Encrypted at rest on the server using AES-256-GCM."
    },
    "sentAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when this message was sent"
    },
    "phase": {
      "type": "string",
      "description": "Negotiation phase active when this message was sent",
      "enum": ["probe", "align", "commit"]
    }
  },
  "additionalProperties": false
}
